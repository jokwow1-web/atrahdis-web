---
import Base from '../../layouts/Base.astro';
import { WA_CTA_URL } from '../../lib/constants';

const certs = [
  { src: '/portfolio/cert-01.webp', alt: 'Sertifikat SBU Klien Atrahdis — SBU Kecil' },
  { src: '/portfolio/cert-02.webp', alt: 'Sertifikat SBU Klien Atrahdis — SBU Menengah' },
  { src: '/portfolio/cert-03.webp', alt: 'Sertifikat SBU Klien Atrahdis — SKK J5' },
  { src: '/portfolio/cert-04.webp', alt: 'Sertifikat SBU Klien Atrahdis — SBU Besar' },
  { src: '/portfolio/cert-05.webp', alt: 'Sertifikat SBU Klien Atrahdis — KTA Asosiasi' },
  { src: '/portfolio/cert-06.webp', alt: 'Sertifikat SBU Klien Atrahdis — SKK J6' },
  { src: '/portfolio/cert-07.webp', alt: 'Sertifikat SBU Klien Atrahdis — SBU Kecil' },
  { src: '/portfolio/cert-08.webp', alt: 'Sertifikat SBU Klien Atrahdis — Serkom' },
  { src: '/portfolio/cert-09.webp', alt: 'Sertifikat SBU Klien Atrahdis — SKK J7' },
  { src: '/portfolio/cert-10.webp', alt: 'Sertifikat SBU Klien Atrahdis — SBU Menengah' },
  { src: '/portfolio/cert-11.webp', alt: 'Sertifikat SBU Klien Atrahdis — ISO 9001' },
  { src: '/portfolio/cert-12.webp', alt: 'Sertifikat SBU Klien Atrahdis — SBU Besar' },
];
---
<Base title="Sertifikat Klien Atrahdis — Portfolio SBU & SKK" description="280+ sertifikat SBU konstruksi telah diproses sejak 2016. Lihat portfolio real case Atrahdis.">
  <!-- Hero -->
  <section class="bg-navy-900 py-16 text-white">
    <div class="mx-auto max-w-6xl px-4 text-center">
      <p class="text-sm font-semibold uppercase tracking-wide text-gold-400">Portfolio</p>
      <h1 class="mt-4 text-3xl font-bold text-white md:text-4xl">Sertifikat Klien Atrahdis</h1>
      <p class="mt-4 text-gray-300">
        280+ sertifikat diproses sejak 2016. Berikut beberapa real case yang telah kami selesaikan untuk klien di seluruh Indonesia.
      </p>
    </div>
  </section>

  <!-- Gallery -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="grid grid-cols-2 gap-4 md:grid-cols-3 md:gap-6 lg:grid-cols-4">
      {certs.map((cert) => (
        <div class="group relative overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm transition hover:border-gold-500/30 hover:shadow-md">
          <img
            src={cert.src}
            alt={cert.alt}
            width="300"
            height="400"
            class="h-48 w-full object-cover transition-transform duration-300 group-hover:scale-105 md:h-56"
            loading="lazy"
          />
          <div class="absolute inset-0 flex items-end bg-gradient-to-t from-black/70 via-transparent to-transparent p-4 opacity-0 transition duration-300 group-hover:opacity-100">
            <p class="text-sm font-medium text-white">{cert.alt.split(' — ')[1]}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-gray-50">
    <div class="mx-auto max-w-6xl px-4 py-20">
      <div class="grid gap-8 sm:grid-cols-3 text-center">
        <div>
          <p class="text-4xl font-bold text-navy-900">280+</p>
          <p class="mt-2 text-gray-600">Sertifikat Diproses</p>
        </div>
        <div>
          <p class="text-4xl font-bold text-navy-900">9+</p>
          <p class="mt-2 text-gray-600">Tahun Pengalaman</p>
        </div>
        <div>
          <p class="text-4xl font-bold text-navy-900">50+</p>
          <p class="mt-2 text-gray-600">Kota di Indonesia</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-navy-900 text-white">
    <div class="mx-auto max-w-6xl px-4 py-20 text-center">
      <h2 class="font-heading text-3xl font-bold text-white md:text-4xl">Jadilah klien berikutnya</h2>
      <p class="mx-auto mt-4 max-w-2xl text-gray-300">Konsultasi gratis untuk audit dokumen SBU Anda. Tanpa biaya, tanpa komitmen.</p>
      <div class="mt-8">
        <a
          href={WA_CTA_URL}
          class="inline-block rounded-lg bg-gold-500 px-10 py-4 font-heading text-lg font-semibold text-navy-900 shadow-lg shadow-gold-500/20 transition hover:bg-gold-400"
        >
          Konsultasi Gratis via WhatsApp →
        </a>
      </div>
    </div>
  </section>
</Base>

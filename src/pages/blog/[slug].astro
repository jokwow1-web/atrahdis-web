---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { WA_CTA_URL } from '../../lib/constants';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const canonical = new URL(`/blog/${post.id}`, Astro.site ?? Astro.url).toString();

const showToc = headings.filter((h) => h.depth === 2).length >= 4;

const allPosts = await getCollection('blog');
const related = allPosts
  .filter((p) => p.id !== post.id && p.data.product === post.data.product)
  .slice(0, 3);

const faqSchema = post.data.faqSchema?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: post.data.faqSchema.map((item) => ({
        '@type': 'Question',
        name: item.q,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.a,
        },
      })),
    }
  : null;
---
<Base title={post.data.title} description={post.data.description} canonical={canonical}>
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <article class="mx-auto max-w-3xl px-4 py-16">
    <a href="/blog" class="text-sm text-gray-500 hover:text-blue-600">← Kembali ke Blog</a>
    <header class="mt-4 border-b border-gray-100 pb-6">
      <p class="text-sm font-semibold uppercase tracking-wide text-gold-400">{post.data.product}</p>
      <h1 class="mt-2 text-4xl font-bold tracking-tight text-gray-900">{post.data.title}</h1>
      <p class="mt-4 text-lg text-gray-600">{post.data.description}</p>
      <time class="mt-4 block text-sm text-gray-400">
        {post.data.publishedAt.toLocaleDateString('id-ID', {
          day: 'numeric',
          month: 'long',
          year: 'numeric',
        })}
      </time>
    </header>

    {post.data.image && (
      <img
        src={post.data.image}
        alt={post.data.title}
        class="mt-8 aspect-video w-full rounded-xl object-cover bg-gray-100"
        loading="eager"
      />
    )}

    {showToc && (
      <nav class="mt-8 rounded-xl border border-gray-200 bg-gray-50 p-5">
        <p class="text-sm font-semibold uppercase tracking-wide text-gray-500">Daftar Isi</p>
        <ol class="mt-3 space-y-1 text-sm">
          {headings.filter((h) => h.depth === 2).map((h) => (
            <li>
              <a href={`#${h.slug}`} class="text-gray-600 hover:text-gold-500">{h.text}</a>
            </li>
          ))}
        </ol>
      </nav>
    )}

    <div class="prose prose-gray mt-10 max-w-none prose-a:text-gold-500 prose-headings:tracking-tight">
      <Content />
    </div>

    {post.data.faqSchema?.length > 0 && (
      <section class="mt-12">
        <h2 class="text-2xl font-bold tracking-tight text-gray-900">Pertanyaan Umum</h2>
        <div class="mt-6 space-y-3">
          {post.data.faqSchema.map((item) => (
            <details class="rounded-lg border border-gray-200 bg-white">
              <summary class="cursor-pointer p-4 font-semibold text-gray-800 hover:text-gold-500">
                {item.q}
              </summary>
              <p class="px-4 pb-4 text-gray-600">{item.a}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    <div class="author-box mt-10 border-t border-gray-200 pt-6">
      <p class="font-bold text-gray-900">Nicx — SBU Specialist sejak 2016</p>
      <p class="mt-1 text-gray-600">280+ SBU diproses. Mitra resmi LPJK dan asosiasi konstruksi.</p>
      <a href="/tentang" class="mt-2 inline-block text-gold-500 hover:text-gold-600">Profil lengkap →</a>
    </div>

    {related.length > 0 && (
      <section class="mt-10">
        <h2 class="text-lg font-semibold text-gray-900">Bacaan terkait</h2>
        <div class="mt-4 grid gap-4 sm:grid-cols-3">
          {related.map((p) => (
            <a href={`/blog/${p.id}`} class="rounded-lg border border-gray-200 p-4 hover:border-gold-500/50 transition">
              <p class="text-xs font-semibold uppercase tracking-wide text-gold-400">{p.data.product}</p>
              <p class="mt-1 text-sm font-medium text-gray-900">{p.data.title}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="mt-12 rounded-2xl bg-navy-900 border border-gold-500/20 p-8">
      <h2 class="text-2xl font-bold tracking-tight">Perlu audit dokumen sebelum submit?</h2>
      <p class="mt-3 max-w-2xl text-gray-300">
        Nicx cek bottleneck berkas Anda dulu sebelum Anda keluar biaya proses. Jika ada titik rawan di OSS,
        KBLI, SKK, atau KSWP, Anda tahu urutannya sejak awal.
      </p>
      <a
        href={`${WA_CTA_URL}?text=Halo%20Nicx%2C%20saya%20ingin%20audit%20dokumen%20SBU&utm_source=blog&utm_medium=organic&utm_campaign=pillar`}
        class="mt-5 inline-block rounded-lg bg-gold-500 px-6 py-3 font-semibold text-white hover:bg-gold-400"
      >
        Konsultasi gratis via WhatsApp
      </a>
    </section>
  </article>
</Base>

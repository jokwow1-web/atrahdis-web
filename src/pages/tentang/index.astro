---
import Base from '../../layouts/Base.astro';
import { IDENTITY } from '../../lib/constants';
---
<Base title="Tentang Atrahdis" description="PT Atrahdis Idea Nusantara — jasa SBU konstruksi sejak 2016. NIB 9120006530734, berdomisili di Jakarta Selatan.">
  <section class="mx-auto max-w-4xl px-4 py-16">
    <h1 class="text-3xl font-bold">Tentang Atrahdis</h1>

    <div class="mt-8 space-y-6 text-gray-700 leading-relaxed">
      <p>
        {IDENTITY.legalName} berdiri sekitar tahun 2017.
        {IDENTITY.founder} personally mengurus SBU konstruksi sejak {IDENTITY.operatingSince} — lebih dari 9 tahun pengalaman.
      </p>
      <p>
        Kualifikasi SBU kami mencakup <strong>K, M, B</strong> (Kecil, Menengah, Besar).
        Bukan K1/K2/M1/M2/B1/B2 — klasifikasi tersebut sudah deprecated.
      </p>

      <div class="rounded-xl bg-gray-50 p-6">
        <h2 class="font-semibold">Data Legal</h2>
        <table class="mt-4 text-sm">
          <tr><td class="pr-4 py-1 font-medium">Nama Legal</td><td>{IDENTITY.legalName}</td></tr>
          <tr><td class="pr-4 py-1 font-medium">NIB</td><td>{IDENTITY.nib}</td></tr>
          <tr><td class="pr-4 py-1 font-medium">Founder</td><td>{IDENTITY.founder}</td></tr>
          <tr><td class="pr-4 py-1 font-medium">Alamat</td><td>{IDENTITY.address}</td></tr>
        </table>
      </div>
    </div>

    <div class="mt-12">
      <a href="/tentang/tim" class="text-blue-600 hover:underline">Lihat tim kami →</a>
    </div>
  </section>
</Base>
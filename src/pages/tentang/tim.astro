---
import Base from '../../layouts/Base.astro';
---
<Base title="Tim Atrahdis" description="Tim PT Atrahdis — Nicx, Febri, Reza, Irwan. PIC per produk SBU & SKK konstruksi.">
  <section class="mx-auto max-w-4xl px-4 py-16">
    <a href="/tentang" class="text-sm text-gray-500 hover:text-blue-600">← Kembali</a>
    <h1 class="mt-4 text-3xl font-bold">Tim Kami</h1>

    <div class="mt-12 grid gap-6 md:grid-cols-2">
      <div class="rounded-xl border p-6">
        <h2 class="text-lg font-semibold">Nicx (Nicky Valiant)</h2>
        <p class="text-sm text-gray-500">Founder & CEO</p>
        <p class="mt-3 text-gray-600">PIC: Strategi & pengembangan bisnis. Mengurus SBU personally sejak 2016.</p>
      </div>
      <div class="rounded-xl border p-6">
        <h2 class="text-lg font-semibold">Febri</h2>
        <p class="text-sm text-gray-500">Operations</p>
        <p class="mt-3 text-gray-600">PIC: Proses pengurusan SBU & koordinasi dengan LPJK.</p>
      </div>
      <div class="rounded-xl border p-6">
        <h2 class="text-lg font-semibold">Reza</h2>
        <p class="text-sm text-gray-500">Client Relations</p>
        <p class="mt-3 text-gray-600">PIC: Handling klien, follow-up dokumen, dan komunikasi.</p>
      </div>
      <div class="rounded-xl border p-6">
        <h2 class="text-lg font-semibold">Irwan</h2>
        <p class="text-sm text-gray-500">Technical Support</p>
        <p class="mt-3 text-gray-600">PIC: Teknis pengurusan SKK & dukungan administrasi.</p>
      </div>
    </div>
  </section>
</Base>
---
import AppLayout from '../../../layouts/AppLayout.astro';
import { fetchDeals } from '../../../lib/orchestrator';

const sessionCookie = Astro.cookies.get('sb-session')?.json();
const token = sessionCookie?.access_token;

let deals: Awaited<ReturnType<typeof fetchDeals>>['deals'] = [];
let error = '';

if (token) {
  const result = await fetchDeals(token);
  deals = result.deals;
  error = result.error || '';
}

function statusBadge(status: string) {
  switch (status) {
    case 'active':
      return 'bg-blue-900/40 text-blue-400 border-blue-700/50';
    case 'completed':
      return 'bg-gold-900/40 text-gold-400 border-gold-700/50';
    case 'on_hold':
      return 'bg-yellow-900/40 text-yellow-400 border-yellow-700/50';
    case 'cancelled':
      return 'bg-red-900/40 text-red-400 border-red-700/50';
    default:
      return 'bg-gray-800 text-gray-400 border-gray-700';
  }
}

function statusLabel(status: string) {
  switch (status) {
    case 'active': return 'Aktif';
    case 'completed': return 'Selesai';
    case 'on_hold': return 'Tertunda';
    case 'cancelled': return 'Dibatalkan';
    default: return 'Draft';
  }
}
---

<AppLayout title="Deals — Atrahdis">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <h1 class="font-heading text-2xl font-bold text-white">Deals</h1>
      <a
        href="/app/deals/new"
        class="inline-flex items-center rounded-lg bg-gold-600 px-4 py-2 text-sm font-semibold text-white hover:bg-gold-500 transition-colors"
      >
        + Deal Baru
      </a>
    </div>

    {error && (
      <div class="rounded-lg border border-red-700/50 bg-red-900/20 p-4 text-sm text-red-300">
        Gagal memuat deals: {error}
      </div>
    )}

    {deals.length === 0 && !error && (
      <div class="rounded-xl border border-navy-700/50 bg-navy-900/40 p-8 text-center">
        <p class="text-gray-400 text-sm">Belum ada deal. Mulai dengan membuat deal baru.</p>
        <a href="/app/deals/new" class="mt-4 inline-flex items-center rounded-lg bg-gold-600 px-4 py-2 text-sm font-semibold text-white hover:bg-gold-500 transition-colors">
          Buat Deal Pertama
        </a>
      </div>
    )}

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
      {deals.map((deal) => (
        <a
          href={`/app/deals/${deal.id}`}
          class="group block rounded-xl border border-navy-700/50 bg-navy-900/40 p-5 hover:border-navy-600 transition-colors"
        >
          <div class="flex items-start justify-between">
            <div>
              <p class="text-xs text-gray-500">{deal.package_name} · {deal.sub_bidang}</p>
              <h3 class="mt-1 text-sm font-semibold text-white group-hover:text-gold-400 transition-colors">
                {deal.client_company || deal.client_name || 'Deal'}
              </h3>
            </div>
            <span class={`shrink-0 text-[10px] px-2 py-0.5 rounded border ${statusBadge(deal.status)}`}>
              {statusLabel(deal.status)}
            </span>
          </div>

          <div class="mt-4">
            <div class="flex items-center justify-between text-xs text-gray-400 mb-1">
              <span>Progress</span>
              <span>{deal.current_step}/{deal.total_steps} langkah</span>
            </div>
            <div class="h-2 w-full bg-navy-800 rounded-full overflow-hidden">
              <div
                class="h-full bg-gold-600 rounded-full transition-all"
                style={{ width: `${deal.progress_percent}%` }}
              />
            </div>
          </div>

          <p class="mt-3 text-[11px] text-gray-500">
            {new Date(deal.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })}
          </p>
        </a>
      ))}
    </div>
  </div>
</AppLayout>

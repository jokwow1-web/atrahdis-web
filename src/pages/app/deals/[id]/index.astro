---
export const prerender = false;
import AppLayout from '../../../../layouts/AppLayout.astro';
import DealProgress from '../../../../components/app/DealProgress.tsx';
import PaymentButton from '../../../../components/app/PaymentButton.tsx';
import { fetchDealDetail } from '../../../../lib/orchestrator';

const { id } = Astro.params;
const sessionCookie = Astro.cookies.get('sb-session')?.json();
const token = sessionCookie?.access_token;

let deal: Awaited<ReturnType<typeof fetchDealDetail>>['deal'];
let error = '';

if (token && id) {
  const result = await fetchDealDetail(token, id);
  deal = result.deal;
  error = result.error || '';
}

const currentTab = Astro.url.searchParams.get('tab') || 'progress';
---
export const prerender = false;

<AppLayout title={`${deal?.client_company || 'Deal'} — Atrahdis`}>
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <a href="/app/deals" class="text-xs text-gray-500 hover:text-gray-300 transition-colors">← Kembali ke Deals</a>
        <h1 class="mt-1 font-heading text-2xl font-bold text-white">{deal?.client_company || 'Deal'}</h1>
        <p class="text-sm text-gray-400">{deal?.package_name} · {deal?.sub_bidang}</p>
      </div>
      <a
        href={`/app/deals/${id}/upload`}
        class="inline-flex items-center rounded-lg bg-gold-600 px-4 py-2 text-sm font-semibold text-white hover:bg-gold-500 transition-colors"
      >
        Upload Dokumen
      </a>
    </div>

    {error && (
      <div class="rounded-lg border border-red-700/50 bg-red-900/20 p-4 text-sm text-red-300">
        Gagal memuat deal: {error}
      </div>
    )}

    {deal && (
      <>
        <!-- Progress Section -->
        <div class="rounded-xl border border-navy-700/50 bg-navy-900/40 p-6">
          <h2 class="text-sm font-semibold text-white mb-4">Progress</h2>
          <DealProgress steps={deal.steps} client:load />
        </div>

        <!-- Tabs -->
        <div class="border-b border-navy-700/50">
          <nav class="flex gap-6">
            <a
              href={`?tab=dokumen`}
              class={`pb-3 text-sm font-medium border-b-2 transition-colors ${currentTab === 'dokumen' ? 'border-gold-400 text-gold-400' : 'border-transparent text-gray-400 hover:text-white'}`}
            >
              Dokumen
            </a>
            <a
              href={`?tab=pembayaran`}
              class={`pb-3 text-sm font-medium border-b-2 transition-colors ${currentTab === 'pembayaran' ? 'border-gold-400 text-gold-400' : 'border-transparent text-gray-400 hover:text-white'}`}
            >
              Pembayaran
            </a>
          </nav>
        </div>

        {currentTab === 'dokumen' && (
          <div class="rounded-xl border border-navy-700/50 bg-navy-900/40 p-6">
            <h2 class="text-sm font-semibold text-white mb-4">Dokumen</h2>
            {deal.documents.length === 0 ? (
              <p class="text-sm text-gray-400">Belum ada dokumen. <a href={`/app/deals/${id}/upload`} class="text-gold-400 hover:text-gold-300">Upload sekarang →</a></p>
            ) : (
              <ul class="divide-y divide-navy-700/50">
                {deal.documents.map((doc) => (
                  <li class="py-3 flex items-center justify-between">
                    <div>
                      <p class="text-sm text-white">{doc.label}</p>
                      <p class="text-xs text-gray-500">{doc.doc_type}</p>
                    </div>
                    <div class="flex items-center gap-2">
                      {doc.confidence != null && (
                        <span class="text-[10px] bg-gold-900/40 text-gold-400 px-2 py-0.5 rounded border border-gold-700/50">
                          {(doc.confidence * 100).toFixed(0)}%
                        </span>
                      )}
                      <span class={`text-[10px] px-2 py-0.5 rounded border ${
                        doc.status === 'validated' ? 'bg-gold-900/40 text-gold-400 border-gold-700/50' :
                        doc.status === 'failed' ? 'bg-red-900/40 text-red-400 border-red-700/50' :
                        doc.status === 'uploaded' ? 'bg-blue-900/40 text-blue-400 border-blue-700/50' :
                        'bg-gray-800 text-gray-400 border-gray-700'
                      }`}>
                        {doc.status === 'validated' ? 'Tervalidasi' :
                         doc.status === 'failed' ? 'Gagal' :
                         doc.status === 'uploaded' ? 'Diunggah' :
                         doc.status === 'rejected' ? 'Ditolak' : 'Belum diunggah'}
                      </span>
                    </div>
                  </li>
                ))}
              </ul>
            )}
          </div>
        )}

        {currentTab === 'pembayaran' && (
          <div class="rounded-xl border border-navy-700/50 bg-navy-900/40 p-6">
            <h2 class="text-sm font-semibold text-white mb-4">Pembayaran</h2>
            {deal.payments.length === 0 ? (
              <p class="text-sm text-gray-400">Belum ada pembayaran.</p>
            ) : (
              <ul class="divide-y divide-navy-700/50">
                {deal.payments.map((pay) => (
                  <li class="py-3 flex items-center justify-between">
                    <div>
                      <p class="text-sm text-white">{pay.description || `Pembayaran #${pay.id.slice(0, 6)}`}</p>
                      <p class="text-xs text-gray-500">{new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(pay.amount)}</p>
                    </div>
                    <div className="flex items-center gap-3">
                      <span class={`text-[10px] px-2 py-0.5 rounded border ${
                        pay.status === 'paid' ? 'bg-gold-900/40 text-gold-400 border-gold-700/50' :
                        pay.status === 'failed' ? 'bg-red-900/40 text-red-400 border-red-700/50' :
                        'bg-yellow-900/40 text-yellow-400 border-yellow-700/50'
                      }`}>
                        {pay.status === 'paid' ? 'Lunas' : pay.status === 'failed' ? 'Gagal' : 'Menunggu'}
                      </span>
                      {pay.status === 'pending' && pay.snap_token && (
                        <PaymentButton snapToken={pay.snap_token} amount={pay.amount} client:load />
                      )}
                    </div>
                  </li>
                ))}
              </ul>
            )}
          </div>
        )}
      </>
    )}
  </div>
</AppLayout>

---
import AppLayout from "../../../../layouts/App.astro";
import DealProgress from "../../../../components/app/DealProgress";
import DocUpload from "../../../../components/app/DocUpload";
import PaymentButton from "../../../../components/app/PaymentButton";
import { createSupabaseServerClient } from "../../../../lib/supabase";

const { id } = Astro.params;
const supabase = createSupabaseServerClient(Astro.cookies, Astro.request.headers);

const { data: { user }, error: userError } = await supabase.auth.getUser();

if (userError || !user) {
  return Astro.redirect("/app/login");
}

const { data: deal, error: dealError } = await supabase
  .from("deals")
  .select("*")
  .eq("id", id)
  .single();

const { data: documents } = await supabase
  .from("documents")
  .select("*")
  .eq("deal_id", id)
  .order("uploaded_at", { ascending: false });

const { data: steps } = await supabase
  .from("deal_steps")
  .select("*")
  .eq("deal_id", id)
  .order("step_order", { ascending: true });

const { data: payments } = await supabase
  .from("payment_schedules")
  .select("*")
  .eq("deal_id", id)
  .order("due_date", { ascending: true });
---
<AppLayout title={deal ? `Deal ${deal.package_code}` : 'Deal Detail'}>
  <div class="min-h-screen bg-slate-50">
    <header class="border-b bg-white">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4">
        <a href="/app/deals" class="text-sm text-slate-600 hover:text-slate-900">← Kembali ke Deals</a>
        <button
          id="logout-btn"
          class="rounded-lg border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50"
        >
          Logout
        </button>
      </div>
    </header>

    <main class="mx-auto max-w-5xl px-4 py-8">
      {
        dealError || !deal ? (
          <div class="rounded-lg bg-red-50 p-4 text-sm text-red-700">Deal tidak ditemukan.</div>
        ) : (
          <div class="grid gap-6 lg:grid-cols-3">
            <div class="lg:col-span-2 space-y-6">
              <div class="rounded-xl border bg-white p-6 shadow-sm">
                <div class="flex items-start justify-between">
                  <div>
                    <h1 class="text-xl font-bold text-slate-900">
                      {deal.package_code || 'Deal'} — {deal.tier || '-'}
                    </h1>
                    <p class="mt-1 text-sm text-slate-500">
                      {deal.classification || '-'} / {deal.subclassification || '-'}
                    </p>
                  </div>
                  <span
                    class={`inline-flex rounded-full px-2.5 py-0.5 text-xs font-medium ${
                      deal.status === 'completed'
                        ? 'bg-green-100 text-green-700'
                        : deal.status === 'in_progress'
                          ? 'bg-blue-100 text-blue-700'
                          : 'bg-slate-100 text-slate-700'
                    }`}
                  >
                    {deal.status || 'draft'}
                  </span>
                </div>

                <div class="mt-4 grid grid-cols-2 gap-4 text-sm">
                  <div>
                    <p class="text-slate-500">Harga</p>
                    <p class="font-semibold text-slate-900">Rp {deal.price_idr?.toLocaleString('id-ID') || '-'}</p>
                  </div>
                  {deal.sbu_number && (
                    <div>
                      <p class="text-slate-500">Nomor SBU</p>
                      <p class="font-semibold text-slate-900">{deal.sbu_number}</p>
                    </div>
                  )}
                </div>
              </div>

              <DealProgress client:load steps={steps || []} dealId={deal.id} />

              <DocUpload client:load dealId={deal.id} documents={documents || []} />
            </div>

            <div class="space-y-6">
              <PaymentButton client:load deal={deal} payments={payments || []} />

              <div class="rounded-xl border bg-white p-5 shadow-sm">
                <h3 class="font-semibold text-slate-900">Info Deal</h3>
                <dl class="mt-3 space-y-2 text-sm">
                  <div class="flex justify-between">
                    <dt class="text-slate-500">ID</dt>
                    <dd class="font-mono text-slate-900">{deal.id.slice(0, 8)}...</dd>
                  </div>
                  {deal.created_at && (
                    <div class="flex justify-between">
                      <dt class="text-slate-500">Dibuat</dt>
                      <dd class="text-slate-900">{new Date(deal.created_at).toLocaleDateString('id-ID')}</dd>
                    </div>
                  )}
                  {deal.sbu_issued_at && (
                    <div class="flex justify-between">
                      <dt class="text-slate-500">Terbit</dt>
                      <dd class="text-slate-900">{new Date(deal.sbu_issued_at).toLocaleDateString('id-ID')}</dd>
                    </div>
                  )}
                </dl>
              </div>
            </div>
          </div>
        )
      }
    </main>
  </div>

  <script>
    import { createClient } from '@supabase/supabase-js';
    const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
    const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
    const supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

    document.getElementById('logout-btn')?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = '/app/login';
    });
  </script>
</AppLayout>

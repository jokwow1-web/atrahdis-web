---
import AppLayout from "../../layouts/App.astro";
---
<AppLayout title="Login">
  <div class="flex min-h-screen items-center justify-center bg-slate-100 px-4">
    <div class="w-full max-w-md rounded-2xl bg-white p-8 shadow-lg">
      <div class="mb-8 text-center">
        <a href="/" class="text-2xl font-bold tracking-tight text-slate-900">Atrahdis</a>
        <p class="mt-2 text-sm text-slate-500">Login ke portal Atrahdis</p>
      </div>

      <form id="login-form" class="space-y-4">
        <div>
          <label for="email" class="mb-1 block text-sm font-medium text-slate-700">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="nama@perusahaan.com"
            class="w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20"
          />
        </div>

        <button
          type="submit"
          id="submit-btn"
          class="w-full rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500/20"
        >
          Kirim Magic Link
        </button>
      </form>

      <div id="status" class="mt-4 hidden text-center text-sm"></div>

      <a href="/" class="mt-6 block text-center text-sm text-slate-500 hover:text-slate-700">
        ← Kembali ke Beranda
      </a>
    </div>
  </div>

  <script>
    import { createClient } from '@supabase/supabase-js';

    const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
    const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
    const supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

    const form = document.getElementById('login-form');
    const btn = document.getElementById('submit-btn');
    const status = document.getElementById('status');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.disabled = true;
      btn.textContent = 'Mengirim...';
      status.classList.add('hidden');

      const email = form.email.value;

      const { error } = await supabase.auth.signInWithOtp({
        email,
        options: {
          emailRedirectTo: `${window.location.origin}/app/callback`,
        },
      });

      if (error) {
        status.textContent = error.message || 'Gagal mengirim link. Coba lagi.';
        status.className = 'mt-4 text-center text-sm text-red-600';
      } else {
        status.textContent = 'Link login sudah dikirim ke email Anda. Silakan cek inbox.';
        status.className = 'mt-4 text-center text-sm text-green-600';
      }

      btn.disabled = false;
      btn.textContent = 'Kirim Magic Link';
    });
  </script>
</AppLayout>

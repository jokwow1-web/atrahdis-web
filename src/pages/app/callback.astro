---
export const prerender = false;
// Callback handler sedang dalam maintenance
const next = Astro.url.searchParams.get('next') || '/app';
---
export const prerender = false;
<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/logo.png" type="image/png" />
    <title>Redirect — Atrahdis</title>
    <meta http-equiv="refresh" content={`3;url=${next}`} />
  </head>
  <body class="flex min-h-screen items-center justify-center bg-navy-900 font-sans text-gray-100 antialiased">
    <div class="text-center">
      <p class="text-lg font-semibold">Sedang mengalihkan...</p>
      <p class="mt-2 text-sm text-gray-400">Jika tidak berpindah, <a href={next} class="text-gold-400 hover:text-gold-500">klik di sini</a>.</p>
    </div>
  </body>
</html>

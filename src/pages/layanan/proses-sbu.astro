---
import Base from '../../layouts/Base.astro';
import { WA_CTA_URL } from '../../lib/constants';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const processPosts = allPosts.filter((p) =>
  p.id.includes('cara') || p.id.includes('timeline') || p.id.includes('submit') ||
  p.id.includes('dokumen') || p.id.includes('proses') || p.id.includes('checklist')
).slice(0, 6);
---

<Base
  title="Proses Pengurusan SBU — Step by Step"
  description="Alur lengkap pengurusan SBU dari persiapan dokumen sampai sertifikat keluar. Timeline, checklist, dan tips agar tidak ditolak LPJK."
>
  <!-- Hero -->
  <section class="bg-navy-900 text-white">
    <div class="mx-auto max-w-6xl px-4 py-20 md:py-28">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-wide text-gold-400">Layanan Cluster</p>
        <h1 class="mt-4 font-heading text-4xl font-extrabold leading-tight tracking-tight text-white md:text-5xl">
          Proses Pengurusan SBU
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-gray-300 md:text-xl">
          Dari persiapan dokumen sampai sertifikat keluar. Alur, timeline, dan checklist untuk setiap kualifikasi.
        </p>
      </div>
    </div>
  </section>

  <!-- Process Steps -->
  <section class="mx-auto max-w-6xl px-4 py-20">
    <h2 class="text-2xl font-bold tracking-tight text-gray-900">5 Langkah Pengurusan SBU</h2>
    <div class="mt-8 space-y-6">
      <div class="flex gap-4 rounded-xl border border-gray-200 bg-white p-6">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gold-500 font-bold text-white">1</div>
        <div>
          <h3 class="text-lg font-semibold text-gray-900">Audit Dokumen</h3>
          <p class="mt-1 text-gray-600">Cek kelengkapan NIB, KBLI, SKK, akta, NPWP, dan KSWP. Identifikasi bottleneck sebelum submit.</p>
        </div>
      </div>
      <div class="flex gap-4 rounded-xl border border-gray-200 bg-white p-6">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gold-500 font-bold text-white">2</div>
        <div>
          <h3 class="text-lg font-semibold text-gray-900">Perbaikan & Sinkronisasi</h3>
          <p class="mt-1 text-gray-600">Perbaiki data yang tidak sinkron di OSS, update KBLI, dan pastikan SKK aktif.</p>
        </div>
      </div>
      <div class="flex gap-4 rounded-xl border border-gray-200 bg-white p-6">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gold-500 font-bold text-white">3</div>
        <div>
          <h3 class="text-lg font-semibold text-gray-900">Submit ke LPJK</h3>
          <p class="mt-1 text-gray-600">Pengajuan online melalui sistem LPJK. Dokumen diverifikasi otomatis dan manual.</p>
        </div>
      </div>
      <div class="flex gap-4 rounded-xl border border-gray-200 bg-white p-6">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gold-500 font-bold text-white">4</div>
        <div>
          <h3 class="text-lg font-semibold text-gray-900">Verifikasi & Koreksi</h3>
          <p class="mt-1 text-gray-600">Jika ada koreksi dari LPJK, perbaiki dan submit ulang. Proses ini bisa berulang.</p>
        </div>
      </div>
      <div class="flex gap-4 rounded-xl border border-gray-200 bg-white p-6">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gold-500 font-bold text-white">5</div>
        <div>
          <h3 class="text-lg font-semibold text-gray-900">Sertifikat Keluar</h3>
          <p class="mt-1 text-gray-600">SBU aktif dan terdaftar di LPJK. Siap digunakan untuk tender dan kontrak.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline by Qualification -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <h2 class="text-2xl font-bold tracking-tight text-gray-900">Timeline per Kualifikasi</h2>
    <div class="mt-6 overflow-hidden rounded-xl border border-gray-200">
      <table class="w-full text-left text-sm">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 font-semibold text-gray-900">Kualifikasi</th>
            <th class="px-6 py-3 font-semibold text-gray-900">Durasi</th>
            <th class="px-6 py-3 font-semibold text-gray-900">Dokumen Utama</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <tr class="bg-white">
            <td class="px-6 py-4 font-medium text-gray-900">SBU Kecil (K)</td>
            <td class="px-6 py-4 text-gray-600">3–7 hari kerja</td>
            <td class="px-6 py-4 text-gray-600">NIB, KBLI, SKK aktif</td>
          </tr>
          <tr class="bg-white">
            <td class="px-6 py-4 font-medium text-gray-900">SBU Menengah (M)</td>
            <td class="px-6 py-4 text-gray-600">14–21 hari kerja</td>
            <td class="px-6 py-4 text-gray-600">+ laporan keuangan KAP, pengalaman proyek</td>
          </tr>
          <tr class="bg-white">
            <td class="px-6 py-4 font-medium text-gray-900">SBU Besar (B)</td>
            <td class="px-6 py-4 text-gray-600">30–60 hari kerja</td>
            <td class="px-6 py-4 text-gray-600">+ modal besar, tenaga ahli lengkap, referensi proyek</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Related Articles -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <h2 class="text-2xl font-bold tracking-tight text-gray-900">Artikel Proses SBU</h2>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {processPosts.map((post) => (
        <a
          href={`/blog/${post.id}`}
          class="rounded-lg border border-gray-200 p-4 hover:border-gold-500/50 transition"
        >
          <p class="text-xs font-semibold uppercase tracking-wide text-gold-400">{post.data.product}</p>
          <p class="mt-1 text-sm font-medium text-gray-900">{post.data.title}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-navy-900 text-white">
    <div class="mx-auto max-w-6xl px-4 py-20 text-center">
      <h2 class="font-heading text-3xl font-bold text-white md:text-4xl">Siap mulai proses SBU?</h2>
      <p class="mx-auto mt-4 max-w-2xl text-gray-300">Audit dokumen gratis untuk memastikan persiapan Anda sudah tepat sebelum submit ke LPJK.</p>
      <div class="mt-8">
        <a
          href={`${WA_CTA_URL}?text=Halo%20Nicx%2C%20saya%20ingin%20audit%20dokumen%20SBU`}
          class="inline-block rounded-lg bg-gold-500 px-10 py-4 font-heading text-lg font-semibold text-navy-900 shadow-lg shadow-gold-500/20 transition hover:bg-gold-400"
        >
          Konsultasi Gratis via WhatsApp →
        </a>
      </div>
    </div>
  </section>
</Base>